# Notion Janitor environment example

# Ultimate Brain / Notion
NOTION_TOKEN=ntn_your_notion_integration_token_here
NOTION_DATABASE_ID=your_notes_database_id_here

# Kimi summarisation
KIMI_API_KEY=sk-kimi-your_kimi_api_key_here
KIMI_MODEL=kimi-k2.5-thinking
KIMI_TEMPERATURE=0.7
KIMI_MAX_TOKENS=500

# Telegram review surface
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=123456789

# Scanner behaviour
CUTOFF_DAYS=60
STALE_NOTE_LIMIT=20
SCHEDULE_DAY=mon
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# Local state / logging
STATE_DB_PATH=data/janitor.db
LOG_FILE=/var/log/notion-janitor.log
